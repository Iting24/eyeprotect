<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Eyeprotect" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_teal</item>
        <item name="colorSecondary">@color/accent_orange</item>
        <item name="android:windowBackground">@color/light_background</item>
        <item name="android:statusBarColor">@color/light_background</item>
        <item name="android:navigationBarColor">@color/light_nav_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Widget.Eyeprotect.BottomNavigation.ActiveIndicator" parent="">
        <item name="android:color">@color/nav_selected_background</item>
        <item name="android:width">54dp</item>
        <item name="android:height">34dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Eyeprotect.NavIndicator</item>
    </style>

    <style name="ShapeAppearance.Eyeprotect.NavIndicator" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">19dp</item>
    </style>

    <style name="TextAppearance.Eyeprotect.BottomNavigation.Label" parent="">
        <item name="android:textSize">11sp</item>
        <item name="android:lineHeight">13sp</item>
        <item name="android:fontFamily">sans</item>
    </style>
</resources>
